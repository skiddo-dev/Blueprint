{
  "name": "blueprint",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:live": "node scripts/test-live.mjs",
    "test:boot": "node scripts/boot-smoke.mjs",
    "build:raves-books-pitch-deck": "node --no-warnings scripts/build-raves-books-pitch-deck.mjs",
    "gen:ios": "node scripts/gen-ios-config.ts",
    "gen:ios:check": "node scripts/gen-ios-config.ts && git diff --exit-code -- ios/Blueprint/Models/BlueprintConfig.generated.swift"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-node": "^5.5.0",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/leaflet": "^1.9.12",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.6",
    "@vitest/coverage-v8": "^4.1.8",
    "svelte": "^5.56.0",
    "svelte-check": "^4.5.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@auth/sveltekit": "^1.7.0",
    "chart.js": "^4.4.7",
    "dompurify": "^3.4.8",
    "dotenv": "^16.4.7",
    "leaflet": "^1.9.4",
    "mongodb": "^6.12.0",
    "openai": "^4.80.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.15.2",
    "svelte-chartjs": "^4.0.0",
    "svelte-dnd-action": "^0.9.51",
    "zod": "^3.25.76"
  },
  "overrides": {
    "cookie": "^0.7.0"
  },
  "type": "module"
}
