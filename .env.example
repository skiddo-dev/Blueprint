# ── Microsoft Azure AD — used for BOTH user login (Auth.js) and Graph API ───
# Auth.js reads these names automatically:
AUTH_MICROSOFT_ENTRA_ID_ID=your-azure-app-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-azure-app-client-secret
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=your-azure-tenant-id

# Fallback names (kept for compatibility — same values as above):
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# Mailbox to read flagged emails from (required for app-only / client-credentials flow)
AZURE_USER_EMAIL=mailbox@yourdomain.com

# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-a-real-secret

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Model used for email-to-task extraction. Defaults to gpt-4o-mini (fast, cheap,
# supports strict Structured Outputs). Override with e.g. gpt-4.1-mini.
OPENAI_MODEL=gpt-4o-mini

# ── Email push (Microsoft Graph webhooks) ────────────────────────────────────
# When both are set AND APP_BASE_URL is a public https origin, the app subscribes
# to the mailbox and turns flagged emails into tasks in real time (no manual
# "Sync Emails" click). Leave APP_BASE_URL unset locally — Graph can't call back
# to localhost, so the subscription/background jobs are skipped in dev.
APP_BASE_URL=https://your-app.example.com
# Random secret echoed by Graph as `clientState`; the webhook rejects anything else.
GRAPH_WEBHOOK_SECRET=change-me-to-a-long-random-string

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/
MONGO_DB_NAME=blueprint

# ── ATTOM Data (warehouse prospecting) ───────────────────────────────────────
# Powers the admin Prospects page (warehouse leads near Bloomfield Hills, MI).
# Without a key the page falls back to realistic mock data, so it's fully usable
# in dev/demo. Get a key at https://api.developer.attomdata.com/.
ATTOM_API_KEY=
# Optional overrides:
# ATTOM_API_BASE=https://api.gateway.attomdata.com/propertyapi/v1.0.0
# Property-type filter sent to ATTOM. Defaults to WAREHOUSE; set to whatever your
# subscription's data dictionary uses for industrial/warehouse properties.
# ATTOM_PROPERTY_TYPE=WAREHOUSE

# ── Access control ──────────────────────────────────────────────────────────
# Comma-separated admin emails — always admin even before provisioned in DB.
ADMIN_EMAILS=you@yourdomain.com

# ── Optional tuning ─────────────────────────────────────────────────────────
MAX_ATTACHMENT_SIZE_MB=10
MAX_ATTACHMENTS_PER_EMAIL=5
