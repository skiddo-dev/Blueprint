# Microsoft Azure AD — client credentials (app-only) flow
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_USER_EMAIL=mailbox@yourdomain.com   # Mailbox to read (required for app-only flow)

# OpenAI
OPENAI_API_KEY=sk-...

# MongoDB
MONGODB_URI=mongodb://localhost:27017/
MONGO_DB_NAME=blueprint

# Access control — comma-separated emails that are ALWAYS admin (bootstrap so you're
# never locked out before provisioning others via the in-app "User Access" panel).
ADMIN_EMAILS=you@yourdomain.com

# Optional tuning
MAX_ATTACHMENT_SIZE_MB=10
MAX_ATTACHMENTS_PER_EMAIL=5
