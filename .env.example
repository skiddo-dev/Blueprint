# ── Microsoft Azure AD — used for BOTH user login (Auth.js) and Graph API ───
# Auth.js reads these names automatically:
AUTH_MICROSOFT_ENTRA_ID_ID=your-azure-app-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-azure-app-client-secret
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=your-azure-tenant-id

# Fallback names (kept for compatibility — same values as above):
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# Central mailbox to read flagged emails from (app-only / client-credentials flow).
# Always scanned. Optional once PM mailboxes are configured (see PM_MAILBOXES).
AZURE_USER_EMAIL=mailbox@yourdomain.com

# Multi-mailbox sync: flagged email is pulled from EVERY PM's own inbox.
# By default the scanned set is every provisioned user with the 'pm' role, so
# adding a PM = provisioning them (no change here needed). Set PM_MAILBOXES to a
# comma-separated list to override that auto-discovery with an explicit set.
# Requires the app's Mail.Read APPLICATION permission to cover these mailboxes
# (if you use an Exchange Application Access Policy, include them in its scope).
# PM_MAILBOXES=ben@yourdomain.com,andrew@yourdomain.com,kris@yourdomain.com

# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-a-real-secret

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Model used for email-to-task extraction. Defaults to gpt-4o-mini (fast, cheap,
# supports strict Structured Outputs). Override with e.g. gpt-4.1-mini.
OPENAI_MODEL=gpt-4o-mini
# Admin key (sk-admin-…) for the org Costs API behind the /infra spend page. This
# is DISTINCT from OPENAI_API_KEY — a project key can't read org-level costs.
# Leave unset to hide the OpenAI card. Create one at platform.openai.com → admin keys.
# OPENAI_ADMIN_KEY=sk-admin-...

# ── Email push (Microsoft Graph webhooks) ────────────────────────────────────
# When both are set AND APP_BASE_URL is a public https origin, the app subscribes
# to the mailbox and turns flagged emails into tasks in real time (no manual
# "Sync Emails" click). Leave APP_BASE_URL unset locally — Graph can't call back
# to localhost, so the subscription/background jobs are skipped in dev.
APP_BASE_URL=https://your-app.example.com
# Random secret echoed by Graph as `clientState`; the webhook rejects anything else.
GRAPH_WEBHOOK_SECRET=change-me-to-a-long-random-string

# ── MongoDB ─────────────────────────────────────────────────────────────────
# Prod is Atlas (a replica set). For transaction code paths locally, run the
# single-node replica set from docker-compose.yml and use the replicaSet URI:
#   MONGODB_URI=mongodb://localhost:27017/?replicaSet=rs0&directConnection=true
MONGODB_URI=mongodb://localhost:27017/
MONGO_DB_NAME=blueprint

# ── Infra spend / billing (admin /infra page) ────────────────────────────────
# The /infra page reads LIVE billing from each provider's official cost API. Every
# var below is OPTIONAL — a provider whose creds are unset just shows a
# "Not configured" card (the page never crashes). See also OPENAI_ADMIN_KEY above.
#
# MongoDB Atlas — org Invoices API. Create a programmatic API key with the
# "Organization Billing Viewer" role (Atlas → Org → Access Manager → API Keys).
# ATLAS_API_PUBLIC_KEY=your-atlas-public-key
# ATLAS_API_PRIVATE_KEY=your-atlas-private-key
# ATLAS_ORG_ID=your-atlas-org-id
#
# Azure — Cost Management Query API. Always set the subscription you want costs for:
# AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
# Then a service principal with the "Cost Management Reader" role on it:
#  • SAME tenant as the sign-in app → just grant the existing Entra SP that role;
#    it falls back to AZURE_CLIENT_ID / _SECRET / _TENANT_ID automatically.
#  • DIFFERENT tenant (e.g. the subscription is in another tenant than sign-in) →
#    create a dedicated read-only SP IN THE SUBSCRIPTION'S TENANT and set these
#    (they take precedence over the sign-in app):
#       az ad sp create-for-rbac --name blueprint-infra-cost \
#         --role "Cost Management Reader" --scopes /subscriptions/<sub-id>
# AZURE_COST_CLIENT_ID=your-cost-sp-app-id
# AZURE_COST_CLIENT_SECRET=your-cost-sp-secret
# AZURE_COST_TENANT_ID=your-cost-sp-tenant-id

# ── Warehouse prospecting (live data) ────────────────────────────────────────
# The admin Prospects page pulls warehouse leads near Bloomfield Hills, MI from
# two FREE, key-less public sources, so it runs live out of the box:
#   • OpenStreetMap (Overpass API) — warehouse locations + footprint-derived size
#   • Oakland County parcel GIS    — assessed/taxable value + class (county only)
# Set USE_MOCK_DATA=true to serve generated demo data instead (offline/dev).
# Optional endpoint overrides (defaults shown):
# OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# OAKLAND_PARCELS_URL=https://gisservices.oakgov.com/arcgis/rest/services/Enterprise/EnterpriseOpenParcelDataMapService/MapServer/1

# ── Access control ──────────────────────────────────────────────────────────
# Comma-separated admin emails — always admin even before provisioned in DB.
ADMIN_EMAILS=you@yourdomain.com

# ── Optional tuning ─────────────────────────────────────────────────────────
MAX_ATTACHMENT_SIZE_MB=10
MAX_ATTACHMENTS_PER_EMAIL=5
# Email sync safety bounds:
GRAPH_FETCH_TIMEOUT_MS=20000   # abort any single Graph request after this long
MAX_SYNC_MESSAGES=200          # cap flagged messages pulled per mailbox per run
# Only sync mail flagged on/after this instant (ISO 8601); older flagged mail is
# ignored. Defaults to 2026-06-08T00:00:00-04:00 (client is Michigan-based).
# EMAIL_SYNC_CUTOFF=2026-06-08T00:00:00-04:00
