/attachments/

# Python bytecode (from scripts/generate-icons.py and similar utilities)
__pycache__/
*.py[cod]

# Logs
*.log

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local-only settings
.claude/settings.local.json

# OS generated files
.DS_Store
Thumbs.db
