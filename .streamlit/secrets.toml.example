# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is git-ignored (it holds the client secret + cookie secret).
#
# Streamlit native auth (st.login / st.user) — Microsoft Entra ID (Azure AD).
# Reuses the same app registration as the Graph email sync.

[auth]
# Must EXACTLY match a "Web" redirect URI registered in the Azure app registration.
# Add http://localhost:8501/oauth2callback for local dev (and your prod URL's
# /oauth2callback path for the deployed app).
redirect_uri = "http://localhost:8501/oauth2callback"

# Random secret used to sign the auth cookie. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "REPLACE_WITH_RANDOM_64_CHAR_HEX"

# From your Azure app registration (same values as AZURE_CLIENT_ID / AZURE_CLIENT_SECRET).
client_id = "your-azure-client-id"
client_secret = "your-azure-client-secret"

# Tenant-specific OIDC discovery doc (replace <TENANT_ID> with AZURE_TENANT_ID).
server_metadata_url = "https://login.microsoftonline.com/<TENANT_ID>/v2.0/.well-known/openid-configuration"