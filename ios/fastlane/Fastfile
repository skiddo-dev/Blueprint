# fastlane — TestFlight pipeline for the Blueprint iOS app.
#
# This automates the "signed upload" that's the only thing left for the App
# Store (see ../README.md → App Store submission). It can't run unattended here:
# it needs a Mac signed into the RAVES Apple Developer account and an App Store
# Connect API key. Full walkthrough in ../TESTFLIGHT.md.
#
# One-time prereqs:
#   brew install xcodegen
#   bundle install                      # installs fastlane (see ../Gemfile)
#   - App record created in App Store Connect for com.ravesinc.blueprint
#   - App Store Connect API key (.p8) downloaded
#
# Then, from the ios/ directory:
#   ASC_KEY_ID=XXXX ASC_ISSUER_ID=yyyy ASC_KEY_PATH=/path/AuthKey_XXXX.p8 \
#     bundle exec fastlane beta

default_platform(:ios)

XCODEPROJ      = "Blueprint.xcodeproj"   # produced by `xcodegen generate` from project.yml
SCHEME         = "Blueprint"
APP_IDENTIFIER = "com.ravesinc.blueprint"
TEAM_ID        = "M86QQRTURU"

platform :ios do
  desc "Build a Release archive and upload it to TestFlight"
  lane :beta do
    # 1. Regenerate the project from project.yml so the build is reproducible
    #    (the same xcodegen flow used for local verification).
    sh("cd .. && xcodegen generate")

    # 2. Authenticate with an App Store Connect API key — no Apple ID / 2FA, and
    #    it works in CI. (Set ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH.)
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
    )

    # 3. Bump the build number past the latest one already on TestFlight so each
    #    upload is unique (App Store Connect rejects duplicates).
    latest = (latest_testflight_build_number(api_key: api_key, initial_build_number: 0) rescue 0)
    increment_build_number(xcodeproj: XCODEPROJ, build_number: (latest + 1).to_s)

    # 4. Provision App Store DISTRIBUTION signing via the API key. Distribution
    #    certs + App Store provisioning profiles need NO registered devices —
    #    unlike the development profile that automatic signing tries to create
    #    during archive, which fails on a device-less team ("Your team has no
    #    devices…"). cert/sigh create + install them.
    cert(api_key: api_key)
    sigh(api_key: api_key, app_identifier: APP_IDENTIFIER, platform: "ios")
    profile_name = lane_context[SharedValues::SIGH_NAME] ||
                   ENV["sigh_#{APP_IDENTIFIER}_appstore_profile-name"]
    UI.user_error!("Could not resolve the App Store profile name from sigh") if profile_name.to_s.empty?
    UI.message("Signing with App Store profile: #{profile_name}")

    # 5. Archive + export a signed App Store .ipa with MANUAL distribution signing
    #    (the cert + profile provisioned above). No devices required.
    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      output_directory: "build",
      clean: true,
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: { APP_IDENTIFIER => profile_name },
        manageAppVersionAndBuildNumber: false,
      },
      xcargs: "CODE_SIGN_STYLE=Manual " \
              "DEVELOPMENT_TEAM=#{TEAM_ID} " \
              "CODE_SIGN_IDENTITY=\"Apple Distribution\" " \
              "PROVISIONING_PROFILE_SPECIFIER=\"#{profile_name}\"",
    )

    # 5. Upload to TestFlight. Internal testers get it automatically once Apple
    #    finishes processing; external distribution is left off (enable in App
    #    Store Connect when you're ready). The build's "What to Test" notes come
    #    from TESTFLIGHT_CHANGELOG if set, else fastlane/changelog.txt.
    changelog = ENV["TESTFLIGHT_CHANGELOG"]
    changelog_file = File.expand_path("changelog.txt", __dir__)
    changelog ||= File.read(changelog_file).strip if File.exist?(changelog_file)
    upload_to_testflight(
      api_key: api_key,
      changelog: changelog,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end
end
